{
  "manifest_version": 3,
  "name": "Gaya Guardrail",
  "version": "1.0.0",
  "description": "LLM UI Action Guardrails for Gaya Browser Automation",
  "permissions": ["activeTab"],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}


